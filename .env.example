# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: default language mode (hinglish | hindi | english)
DEFAULT_LANGUAGE=hinglish

# Optional: default class level (1-10)
DEFAULT_CLASS_LEVEL=5

# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: SQLite database path
DATABASE_PATH=data/classmate.db
